// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              String // "job_poster" | "contractor" | "admin"
  profileImage      String?
  phone             String?
  location          String?
  bio               String?
  skills            String? // JSON array stored as string
  licenseNumber     String?
  yearsExperience   Int?
  rating            Float?   @default(0)
  isVerified        Boolean  @default(false)
  verificationToken String?
  refreshToken      String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  postedJobs            Job[]
  placedBids            Bid[]
  contractsAsContractor Contract[]     @relation("contractor")
  contractsAsPoster     Contract[]     @relation("poster")
  wallet                Wallet?
  sentMessages          Message[]      @relation("sender")
  receivedMessages      Message[]      @relation("receiver")
  raisedDisputes        Dispute[]      @relation("raisedBy")
  givenReviews          Review[]       @relation("reviewer")
  receivedReviews       Review[]       @relation("reviewee")
  transactions          Transaction[]
  notifications         Notification[]
}

model Job {
  id          String    @id @default(cuid())
  posterId    String
  poster      User      @relation(fields: [posterId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String
  budget      Float
  budgetType  String    @default("fixed") // fixed|hourly|negotiable
  currency    String    @default("USD")
  startDate   DateTime?
  endDate     DateTime?
  location    String
  skills      String? // JSON
  status      String    @default("open") // open|in_progress|completed|closed|cancelled
  images      String? // JSON
  documents   String? // JSON
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bids        Bid[]
  contracts   Contract[]
  messages    Message[]
  disputes    Dispute[]
  reviews     Review[]
  estimations Estimation[]
}

model Bid {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contractorId  String
  contractor    User     @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("USD")
  estimatedDays Int?
  proposal      String?
  portfolio     String? // JSON
  certificates  String? // JSON
  documents     String? // JSON array of uploaded file URLs
  milestones    String? // JSON array of { title, description, amount, dueDate }
  status        String   @default("pending") // pending|accepted|declined|withdrawn
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contract Contract?
}

model Contract {
  id                 String    @id @default(cuid())
  jobId              String
  job                Job       @relation(fields: [jobId], references: [id])
  bidId              String    @unique
  bid                Bid       @relation(fields: [bidId], references: [id])
  posterId           String
  poster             User      @relation("poster", fields: [posterId], references: [id])
  contractorId       String
  contractor         User      @relation("contractor", fields: [contractorId], references: [id])
  totalAmount        Float
  currency           String    @default("USD")
  status             String    @default("active") // active|completed|disputed|cancelled
  milestones         String? // JSON
  signedByPoster     DateTime?
  signedByContractor DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  transactions Transaction[]
  dispute      Dispute?
  review       Review?
}

model Wallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Float    @default(0)
  pendingBalance Float    @default(0)
  totalEarned    Float    @default(0)
  currency       String   @default("USD")
  updatedAt      DateTime @updatedAt
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  type        String // credit|debit|withdrawal|fee|refund
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending") // pending|completed|failed
  description String?
  metadata    String? // JSON
  createdAt   DateTime  @default(now())
}

model Message {
  id         String    @id @default(cuid())
  senderId   String
  sender     User      @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  contractId String?
  content    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Dispute {
  id           String    @id @default(cuid())
  contractId   String    @unique
  contract     Contract  @relation(fields: [contractId], references: [id])
  jobId        String?
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  raisedById   String
  raisedBy     User      @relation("raisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  reason       String
  description  String
  amount       Float?
  status       String    @default("open") // open|under_review|resolved
  response     String?
  respondedAt  DateTime?
  resolution   String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id])
  jobId      String?
  job        Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  reviewerId String
  reviewer   User     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String
  reviewee   User     @relation("reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating     Float    @default(5)
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Estimation {
  id            String   @id @default(cuid())
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  estimatedCost Float
  labor         Float
  timeline      Int // in days
  confidence    Float    @default(0.85)
  metadata      String? // JSON
  createdAt     DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      String? // JSON
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
}
