  checkOutTime  String?
  checkInLat    Float?
  checkInLng    Float?
  hoursWorked   Float     @default(8)
  wageForDay    Float     @default(0)
  notes         String?
  createdAt     DateTime  @default(now())

  @@unique([laborId, date])
}

model SiteMaterial {
  id            String    @id @default(cuid())
  siteId        String
  site          SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name          String
  category      String    @default("other")  // cement|steel|bricks|sand|aggregate|wood|electrical|plumbing|tiles|other
  unit          String    @default("pcs")    // bags|kg|tonnes|cubic_m|pieces|metres|liters|other
  currentStock  Float     @default(0)
  minStock      Float     @default(0)
  unitCost      Float     @default(0)
  currency      String    @default("INR")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions  MaterialTransaction[]
}

model MaterialTransaction {
  id            String    @id @default(cuid())
  siteId        String
  site          SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  materialId    String
  material      SiteMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
