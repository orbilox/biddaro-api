model SiteSubcontractor {
  id              String    @id @default(cuid())
  siteId          String
  site            SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  company         String?
  phone           String?
  email           String?
  specialty       String    @default("civil")  // civil|electrical|plumbing|painting|tiling|other
  contractValue   Float     @default(0)
  paidAmount      Float     @default(0)
  currency        String    @default("INR")
  status          String    @default("active")  // active | completed | terminated
