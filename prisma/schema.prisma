// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              String    // "job_poster" | "contractor" | "admin"
  profileImage      String?
  phone             String?
  country           String?   // IN | AE | SG | US
  location          String?
  bio               String?
  skills            String?   // JSON array stored as string
  licenseNumber     String?
  idDocUrl          String?   // Government ID / passport upload URL
  tradeLicenseUrl   String?   // Trade license / contractor license URL
  insuranceCertUrl  String?   // Insurance certificate URL
  verificationStatus String?  @default("none")  // none | pending | verified | rejected
  pushSubs           String?  // JSON: webpush.PushSubscription[] — persists across restarts
  fcmTokens          String?  // JSON: Array<{ token: string, platform: 'web'|'android'|'ios' }>
  notifPrefs         String?  // JSON: { bids, contracts, messages, wallet, disputes } — all true by default
  yearsExperience   Int?
  rating            Float?    @default(0)
  // ── Extended contractor profile ──────────────────────────────────────────
  portfolio         String?   // JSON: PortfolioItem[]
  certifications    String?   // JSON: Certification[]
  workHistory       String?   // JSON: WorkHistoryItem[]
  availability      String?   @default("available")  // available|busy|unavailable
  hourlyRate        Float?
  website           String?
  languages         String?   // JSON: string[]
  serviceRadius     Int?      // miles
  isVerified        Boolean   @default(false)
  verificationToken String?
  refreshToken      String?
  isActive          Boolean   @default(true)
  referralCode      String?   @unique
  referredBy        String?   // stores the referral code used at signup
  connectsBalance   Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  postedJobs            Job[]
  placedBids            Bid[]
  contractsAsContractor Contract[]   @relation("contractor")
  contractsAsPoster     Contract[]   @relation("poster")
  wallet                Wallet?
  sentMessages          Message[]    @relation("sender")
  receivedMessages      Message[]    @relation("receiver")
  raisedDisputes        Dispute[]    @relation("raisedBy")
  givenReviews          Review[]     @relation("reviewer")
  receivedReviews       Review[]     @relation("reviewee")
  transactions          Transaction[]
  notifications         Notification[]
  clarificationsAsked    ClarificationRequest[] @relation("clarificationAsker")
  clarificationsAnswered ClarificationRequest[] @relation("clarificationAnswerer")
  depositRequests        DepositRequest[]
  premiumSubscriptions   PremiumSubscription[]
  installedAddOns        UserAddOn[]
  projectUpdates         ProjectUpdate[]       @relation("projectUpdates")
  pmProjects             PMProject[]           @relation("pmContractor")
  pmDiscussions          PMDiscussion[]        @relation("pmDiscussionAuthor")
  pmDiscussionReplies    PMDiscussionReply[]   @relation("pmReplyAuthor")
  pmFiles                PMFile[]              @relation("pmFileUploader")
  pmTimeEntries          PMTimeEntry[]         @relation("pmTimeUser")
  buildPlans             BuildPlan[]           @relation("buildPlanPoster")
  buildMedia             BuildMedia[]          @relation("buildMediaUploader")
  loanApplications       LoanApplication[]
  siteProjects           SiteProject[]         @relation("siteOwner")
  siteTeams              SiteTeamMember[]      @relation("siteTeamMember")
  referralsGiven         Referral[]            @relation("referrerOf")
  referralReceived       Referral?             @relation("referredBy")
  connectTransactions    ConnectTransaction[]
  inspectTemplates       InspectTemplate[]
  inspectProjects        InspectProject[]
  inspectReports         InspectReport[]
  inspectTasks           InspectTask[]
  inspectReviewNotes     InspectReviewNote[]
  inspectFloorPlans      InspectFloorPlan[]
  inspectSettings        InspectSettings?
  inspectWebhooks        InspectWebhook[]
  inspectSchedules         InspectSchedule[]
  inspectReportVersions    InspectReportVersion[]
  pushLogs                 PushLog[]
  contractorSite           ContractorSite?
}

model Job {
  id          String    @id @default(cuid())
  posterId    String
  poster      User      @relation(fields: [posterId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String
  budget      Float
  budgetType  String    @default("fixed")  // fixed|hourly|negotiable
  currency    String    @default("USD")
  startDate   DateTime?
  endDate     DateTime?
  location    String
  skills      String?   // JSON
  status      String    @default("open")   // open|in_progress|completed|closed|cancelled
  projectType String    @default("standard") // standard|government|corporate
  images      String?   // JSON
  isSponsored   Boolean   @default(false) // free-to-bid job (admin can set)
  documents   String?   // JSON
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bids        Bid[]
  contracts   Contract[]
  messages    Message[]
  disputes    Dispute[]
  reviews     Review[]
  estimations Estimation[]
}

model Bid {
  id            String    @id @default(cuid())
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contractorId  String
  contractor    User      @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String    @default("USD")
  estimatedDays Int?
  proposal      String?
  portfolio     String?   // JSON
  certificates  String?   // JSON
  documents     String?   // JSON array of uploaded file URLs
  milestones    String?   // JSON array of { title, description, amount, dueDate }
  status        String    @default("pending")  // pending|accepted|declined|withdrawn
  isPriority    Boolean   @default(false)
  connectCost   Int       @default(0)     // connects spent on this bid
  withdrawnAt   DateTime?                 // timestamp for 1-hour full-refund window
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contract      Contract?

  @@index([jobId, status])   // perf: refundAllPendingBidders + acceptBid auto-decline
}

model Contract {
  id                  String    @id @default(cuid())
  jobId               String
  job                 Job       @relation(fields: [jobId], references: [id])
  bidId               String    @unique
  bid                 Bid       @relation(fields: [bidId], references: [id])
  posterId            String
  poster              User      @relation("poster", fields: [posterId], references: [id])
  contractorId        String
  contractor          User      @relation("contractor", fields: [contractorId], references: [id])
  totalAmount         Float
  currency            String    @default("USD")
  status              String    @default("active")  // active|completed|disputed|cancelled
  milestones          String?   // JSON
  escrowFunded        Boolean   @default(false)
  escrowAmount        Float     @default(0)
  releasedAmount      Float     @default(0)
  signedByPoster      DateTime?
  signedByContractor  DateTime?
  completedAt         DateTime?
  nocIssuedAt         DateTime?
  nocIssuerNote       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  transactions     Transaction[]
  dispute          Dispute?
  review           Review?
  clarifications   ClarificationRequest[]
  projectUpdates   ProjectUpdate[]
}

model Wallet {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Float     @default(0)
  pendingBalance Float     @default(0)
  totalEarned    Float     @default(0)
  currency       String    @default("USD")
  updatedAt      DateTime  @updatedAt
}

model Transaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractId  String?
  contract    Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  type        String    // credit|debit|withdrawal|fee|refund
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending")  // pending|completed|failed
  description String?
  metadata    String?   // JSON
  createdAt   DateTime  @default(now())
}

model Message {
  id          String    @id @default(cuid())
  senderId    String
  sender      User      @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User      @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  contractId  String?
  content     String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Dispute {
  id           String    @id @default(cuid())
  contractId   String    @unique
  contract     Contract  @relation(fields: [contractId], references: [id])
  jobId        String?
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  raisedById   String
  raisedBy     User      @relation("raisedBy", fields: [raisedById], references: [id], onDelete: Cascade)
  reason       String
  description  String
  amount       Float?
  status       String    @default("open")  // open|under_review|resolved
  response     String?
  respondedAt  DateTime?
  resolution   String?
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Review {
  id          String    @id @default(cuid())
  contractId  String    @unique
  contract    Contract  @relation(fields: [contractId], references: [id])
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  reviewerId  String
  reviewer    User      @relation("reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId  String
  reviewee    User      @relation("reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  rating      Float     @default(5)
  comment     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Estimation {
  id            String    @id @default(cuid())
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  estimatedCost Float
  labor         Float
  timeline      Int       // in days
  confidence    Float     @default(0.85)
  metadata      String?   // JSON
  createdAt     DateTime  @default(now())
}

model ClarificationRequest {
  id           String    @id @default(cuid())
  contractId   String
  contract     Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  askedById    String
  askedBy      User      @relation("clarificationAsker",    fields: [askedById],    references: [id])
  question     String
  answer       String?
  answeredById String?
  answeredBy   User?     @relation("clarificationAnswerer", fields: [answeredById], references: [id])
  status       String    @default("pending") // pending | answered | closed
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  data      String?   // JSON
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model BankSettings {
  id                  String   @id @default(cuid())
  bankName            String
  accountHolderName   String
  accountNumber       String
  routingNumber       String?
  ifscCode            String?
  swiftCode           String?
  ibanNumber          String?
  country             String?   // IN | AE | SG | US
  branch              String?
  bankAddress         String?
  paymentInstructions String?
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DepositRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  transactionId String
  screenshotUrl String
  senderName    String?
  senderBank    String?
  status        String    @default("pending")  // pending | approved | rejected
  adminNote     String?
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Premium Subscriptions ───────────────────────────────────────────────────

model PremiumSubscription {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String    // monthly | quarterly | annual
  amount      Float
  currency    String    @default("USD")
  status      String    @default("active")  // active | cancelled | expired
  autoRenew   Boolean   @default(true)
  startDate   DateTime  @default(now())
  expiresAt   DateTime
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── Live Project Tracking ───────────────────────────────────────────────────

model ProjectUpdate {
  id              String    @id @default(cuid())
  contractId      String
  contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  postedById      String
  postedBy        User      @relation("projectUpdates", fields: [postedById], references: [id], onDelete: Cascade)
  message         String
  progressPercent Int?      // 0–100, optional
  imageUrl        String?
  type            String    @default("update") // update | note | photo | milestone
  createdAt       DateTime  @default(now())
}

// ─── Project Manager Add-On ───────────────────────────────────────────────────

model PMProject {
  id           String    @id @default(cuid())
  contractorId String
  contractor   User      @relation("pmContractor", fields: [contractorId], references: [id], onDelete: Cascade)
  contractId   String?   // optional link to a Biddaro contract
  title        String
  description  String?
  status       String    @default("active")   // active | completed | archived
  color        String    @default("#6366f1")  // hex color for sidebar
  emoji        String    @default("📁")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tasks        PMTask[]
  milestones   PMMilestone[]
  discussions  PMDiscussion[]
  files        PMFile[]
  timeEntries  PMTimeEntry[]
}

model PMTask {
  id          String       @id @default(cuid())
  projectId   String
  project     PMProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   PMMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  parentId    String?
  parent      PMTask?      @relation("subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    PMTask[]     @relation("subtasks")
  title       String
  description String?
  status      String       @default("todo")    // todo | in_progress | in_review | done
  priority    String       @default("medium")  // low | medium | high | urgent
  dueDate     DateTime?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  timeEntries PMTimeEntry[]
}

model PMMilestone {
  id          String    @id @default(cuid())
  projectId   String
  project     PMProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")   // pending | completed
  color       String    @default("#6366f1")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tasks       PMTask[]
}

model PMDiscussion {
  id        String    @id @default(cuid())
  projectId String
  project   PMProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation("pmDiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  replies   PMDiscussionReply[]
}

model PMDiscussionReply {
  id           String       @id @default(cuid())
  discussionId String
  discussion   PMDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User         @relation("pmReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content      Json
  createdAt    DateTime     @default(now())
}

model PMFile {
  id           String    @id @default(cuid())
  projectId    String
  project      PMProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User      @relation("pmFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  name         String
  url          String
  size         Int?
  mimeType     String?
  createdAt    DateTime  @default(now())
}

model PMTimeEntry {
  id          String    @id @default(cuid())
  projectId   String
  project     PMProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        PMTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userId      String
  user        User      @relation("pmTimeUser", fields: [userId], references: [id], onDelete: Cascade)
  description String?
  minutes     Int       // logged time in minutes
  logDate     DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

// ─── Add-Ons Marketplace ─────────────────────────────────────────────────────

model UserAddOn {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addOnSlug   String    // references catalog slug (e.g. "invoice-generator")
  installedAt DateTime  @default(now())
  isActive    Boolean   @default(true)
  settings    String?   // JSON: per-add-on configuration

  @@unique([userId, addOnSlug])
}

// ─── Construction Planner Add-On ──────────────────────────────────────────────

model BuildPlan {
  id          String   @id @default(cuid())
  posterId    String
  poster      User     @relation("buildPlanPoster", fields: [posterId], references: [id], onDelete: Cascade)
  title       String
  description String?
  buildType   String   @default("residential")  // residential|commercial|industrial|renovation|interior
  address     String?
  totalBudget Float?
  currency    String   @default("USD")
  emoji       String   @default("🏗️")
  color       String   @default("#3b82f6")
  coverImage  String?
  status      String   @default("planning")  // planning|in_progress|complete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections  BuildSection[]
  media     BuildMedia[]
  materials BuildPlanMaterial[]
}

model BuildPlanMaterial {
  id            String    @id @default(cuid())
  planId        String
  plan          BuildPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name          String
  category      String    @default("other")   // concrete|steel|wood|electrical|plumbing|roofing|finishing|other
  quantity      Float
  unit          String    @default("pcs")     // pcs|bags|m2|m3|kg|tons|L|m|rolls|sheets
  estimatedCost Float?
  actualCost    Float?
  status        String    @default("pending") // pending|ordered|delivered|installed
  supplier      String?
  notes         String?
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BuildSection {
  id        String   @id @default(cuid())
  planId    String
  plan      BuildPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type      String   // site_map|exterior|interior|plumbing|electrical|structural|hvac|finishes|other
  title     String
  notes     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkItems BuildCheckItem[]
  media      BuildMedia[]
}

model LoanApplication {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanType         String   // home_construction | renovation | equipment | working_capital | personal
  amount           Float
  tenure           Int      // months
  purpose          String
  employmentType   String   // salaried | self_employed | business_owner | contractor
  monthlyIncome    Float
  firstName        String
  lastName         String
  email            String
  phone            String
  address          String
  city             String
  country          String
  documents        String?  // JSON array of URLs
  status           String   @default("pending") // pending | under_review | approved | rejected | disbursed
  adminNote        String?
  approvedAmount   Float?
  interestRate     Float?
  emiAmount        Float?
  reviewedAt       DateTime?
  disbursedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LoanInquiry {
  id                  String   @id @default(cuid())
  loanType            String
  amount              Float
  purpose             String?
  employmentType      String?
  monthlyIncome       Float?
  firstName           String
  lastName            String
  email               String
  phone               String
  address             String?
  city                String?
  country             String   @default("IN")
  razorpayPaymentId       String?
  razorpayOrderId         String?
  razorpaySignature       String?
  razorpaySubscriptionId  String?
  razorpayPlanId          String?
  subscriptionStatus      String?  // authenticated | active | halted | cancelled
  feePaid                 Int      @default(0)  // in paise; 0 for subscription flow
  status                  String   @default("new") // new | contacted | converted | closed
  adminNote           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Pre-payment lead capture — created when user fills personal info on loan form
// before completing Razorpay payment; used for follow-up reminder journey.
model LoanLead {
  id              String    @id @default(cuid())
  name            String
  email           String
  phone           String
  loanType        String?
  amount          Float?
  city            String?
  source          String?           // page path or utm_source
  converted       Boolean   @default(false)
  reminderStage   Int       @default(0)   // 0=no email sent, 1–4=emails sent
  lastReminderAt  DateTime?
  optOut          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  whatsappLogs    WhatsAppLog[]
}

model WhatsAppLog {
  id        String    @id @default(cuid())
  leadId    String?
  phone     String
  stage     Int                              // follow-up stage 1..7
  messageId String?   @unique                // Meta wamid, for status correlation
  status    String    @default("sent")       // sent | delivered | read | failed
  error     String?
  sentAt    DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lead      LoanLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status])
  @@index([sentAt])
}

model BuildCheckItem {
  id        String       @id @default(cuid())
  sectionId String
  section   BuildSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label     String
  isChecked Boolean      @default(false)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

model BuildMedia {
  id        String        @id @default(cuid())
  planId    String
  plan      BuildPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  sectionId String?
  section   BuildSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  addedById String
  addedBy   User          @relation("buildMediaUploader", fields: [addedById], references: [id])
  name      String
  url       String
  mediaType String        @default("image")  // image|blueprint|map|document
  caption   String?
  addedAt   DateTime      @default(now())
}

// ─── OTP Verification ─────────────────────────────────────────────────────────

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit numeric, short-lived — not sensitive to store plain
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Password Reset ────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Referral System ──────────────────────────────────────────────────────────

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("referrerOf", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String   @unique
  referred    User     @relation("referredBy", fields: [referredId], references: [id], onDelete: Cascade)
  reward      Float    @default(10.0)
  status      String   @default("credited")  // credited|pending
  createdAt   DateTime @default(now())
}

// ─── Site Manager Add-On ──────────────────────────────────────────────────────

model SiteProject {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("siteOwner", fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  location      String?
  latitude      Float?
  longitude     Float?
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("active")  // active | completed | on_hold | cancelled
  budget        Float     @default(0)
  currency      String    @default("INR")
  clientName    String?
  clientPhone   String?
  clientEmail   String?
  coverImage    String?
  progressPct   Float     @default(0)
  publicToken   String?   @unique @default(cuid())  // for client portal sharing
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  labor          SiteLabor[]
  attendance     LaborAttendance[]
  materials      SiteMaterial[]
  materialTxns   MaterialTransaction[]
  reports        DailyReport[]
  boqItems       BOQItem[]
  equipment      SiteEquipment[]
  expenses       SiteExpense[]
  invoices       SiteInvoice[]
  subcontractors SiteSubcontractor[]
  milestones     SiteMilestone[]
  leads          SiteLead[]
  designs        DesignDocument[]
  qualityChecks  QualityCheck[]
  procurements   ProcurementOrder[]
  vendorBills    VendorBill[]
  productions    ProductionTask[]
  teamMembers    SiteTeamMember[]
  invites        SiteInvite[]
  issues         SiteIssue[]
}

model SiteLabor {
  id          String    @id @default(cuid())
  siteId      String
  site        SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  role        String    @default("helper")  // mason|carpenter|electrician|plumber|supervisor|helper|other
  dailyWage   Float     @default(0)
  currency    String    @default("INR")
  status      String    @default("active")  // active | inactive
  joinDate    DateTime  @default(now())
  createdAt   DateTime  @default(now())

  attendance  LaborAttendance[]
}

model LaborAttendance {
  id            String    @id @default(cuid())
  siteId        String
  site          SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  laborId       String
  labor         SiteLabor   @relation(fields: [laborId], references: [id], onDelete: Cascade)
