  category      String   @default("material") // material|labor|equipment|service
  description   String?
  amount        Float    @default(0)
  taxAmount     Float    @default(0)
  totalAmount   Float    @default(0)
  currency      String   @default("INR")
  billDate      DateTime @default(now())
  dueDate       DateTime?
  paidDate      DateTime?
  status        String   @default("pending") // pending|approved|paid|overdue|disputed
  paymentMethod String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductionTask {
  id           String   @id @default(cuid())
  siteId       String
  site         SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  category     String   @default("civil") // civil|structural|electrical|plumbing|finishing|external|other
  location     String?
  assignedTo   String?
  startDate    DateTime?
  endDate      DateTime?
  completedAt  DateTime?
  status       String   @default("pending") // pending|in_progress|completed|on_hold|cancelled
  priority     String   @default("medium") // low|medium|high|critical
  progress     Float    @default(0)
  unit         String?
  plannedQty   Float?
  completedQty Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteTeamMember {
  id         String      @id @default(cuid())
  siteId     String
  site       SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation("siteTeamMember", fields: [userId], references: [id], onDelete: Cascade)
  role       String      @default("viewer")  // owner|admin|pm|engineer|supervisor|client|viewer
  invitedBy  String?
  joinedAt   DateTime    @default(now())
  @@unique([siteId, userId])
}

model SiteInvite {
  id         String      @id @default(cuid())
  siteId     String
  site       SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  email      String
  role       String      @default("viewer")
  token      String      @unique @default(cuid())
  status     String      @default("pending")  // pending|accepted|expired
  invitedBy  String
  expiresAt  DateTime
  createdAt  DateTime    @default(now())
}

model SiteIssue {
  id          String      @id @default(cuid())
  siteId      String
  site        SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String      @default("defect")  // defect|safety|rfi|punch|delay|other
  priority    String      @default("medium")  // low|medium|high|critical
  status      String      @default("open")    // open|in_progress|resolved|closed
  location    String?
  reportedBy  String?
  assignedTo  String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Connects Token Ledger ────────────────────────────────────────────────────

model ConnectTransaction {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String   // "purchase" | "debit" | "refund" | "welcome_bonus" | "grant"
  amount            Int      // always positive; direction determined by type
  bidId             String?
  description       String?
  razorpayOrderId   String?
  razorpayPaymentId String?  @unique  // DB-level idempotency: one credit per Razorpay payment
  razorpaySignature String?
  packageKey        String?  // "starter"|"pro"|"power"|"elite"|"bulk"
  createdAt         DateTime @default(now())

  @@index([userId])
}

// ─── Biddaro Inspect — AI Inspection Reports ─────────────────────────────────

model InspectTemplate {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  structure   Json             // parsed sections/headings as JSON
  rawContent  String?          // original template text
  fileUrl     String?          // uploaded .docx / PDF file URL
  projects    InspectProject[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model InspectProject {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId  String?
  template    InspectTemplate? @relation(fields: [templateId], references: [id])
  name        String
  location    String?
  clientName  String?
  clientEmail String?
  description String?
  status      String           @default("active")   // active|completed|archived
  clientPortalToken   String?  @unique  // public token for client-facing portal
  clientPortalEnabled Boolean  @default(false)
  captures    InspectCapture[]
  reports     InspectReport[]
  tasks       InspectTask[]
  floorPlans  InspectFloorPlan[]
  schedules   InspectSchedule[]
  members     InspectProjectMember[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model InspectCapture {
  id          String         @id @default(cuid())
  projectId   String
  project     InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String         // photo|voice|text
  content     String?        // transcribed voice or typed text
  imageUrl    String?
  gpsLat      Float?
  gpsLng      Float?
  annotation  String?
  section     String?        // which report section this belongs to
  severity    String         @default("normal")     // normal|warning|critical
  tags        String[]       @default([])           // freeform trade/area labels
  createdAt   DateTime       @default(now())

  @@index([projectId])
}

model InspectReport {
  id           String         @id @default(cuid())
  projectId    String
  project      InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  status       String         @default("draft")     // draft|review|approved|sent
  content      Json           // structured sections as JSON
  rawMarkdown  String?        // full text for export
  wordFileUrl  String?
  pdfFileUrl   String?
  sentAt        DateTime?
  sentTo        String?
  publicToken         String?   @unique   // random token for shareable client portal link
  publicEnabled       Boolean   @default(false)
  publicExpiry        DateTime?           // optional expiry date for the share link
  publicViewCount     Int       @default(0) // number of times the public link was viewed
  clientSignature     String?             // base64 encoded SVG path from signature pad
  clientSignedByName  String?             // signer's name as entered by client
  clientSignedAt      DateTime?           // timestamp when client signed
  inspectorSignature  String?             // base64 PNG data-URL of inspector's drawn signature
  inspectorSignedAt   DateTime?           // timestamp when inspector applied signature
  tasks            InspectTask[]
  reviewNotes      InspectReviewNote[]
  versions         InspectReportVersion[]
  sectionFeedback  InspectSectionFeedback[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([userId])
}

model InspectReportVersion {
  id            String         @id @default(cuid())
  reportId      String
  report        InspectReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  versionNumber Int
  content       Json           // snapshot of the entire report content at this version
  createdAt     DateTime       @default(now())

  @@index([reportId])
}

model InspectTask {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportId      String
  report        InspectReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  projectId     String
  project       InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  severity      String         @default("normal")   // normal|warning|critical
  status        String         @default("open")      // open|in_progress|done
  assignedTo    String?        // name or email of assignee
  dueDate       DateTime?
  sourceSection String?        // which report section this came from
  sourceFinding String?        // exact finding text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([reportId])
  @@index([userId])
  @@index([projectId])
}

model InspectReviewNote {
  id          String        @id @default(cuid())
  reportId    String
  report      InspectReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String        @default("comment")   // comment|approval|rejection|request_changes|status_change
  content     String
  fromStatus  String?       // for status_change events
  toStatus    String?       // for status_change events
  authorName  String?       // denormalised name snapshot
  createdAt   DateTime      @default(now())

  @@index([reportId])
  @@index([userId])
}

model InspectSectionFeedback {
  id           String        @id @default(cuid())
  reportId     String
  report       InspectReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sectionId    String                       // section id from report content JSON
  sectionTitle String                       // section title for inspector display
  reaction     String                       // thumbs_up | thumbs_down
  comment      String?                      // optional text note from client
  token        String                       // public share token (client session ID)
  createdAt    DateTime      @default(now())

  @@index([reportId])
  @@index([token])
}

model InspectWebhook {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String                       // HTTPS endpoint to POST to
  events    Json                         // String[] e.g. ["report.status_changed","capture.created"]
  secret    String                       // HMAC-SHA256 signing secret
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model InspectFloorPlan {
  id          String         @id @default(cuid())
  projectId   String
  project     InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  imageUrl    String
  pins        Json           // Pin[] = [{ id, x, y, title, severity, notes }]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([userId])
}

model InspectSettings {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String?                        // Appears in report header
  inspectorName String?                        // Override display name
  licenseNo     String?                        // Professional license number
  phone         String?                        // Contact phone for reports
  address       String?                        // Company/office address
  logoUrl       String?                        // Company logo URL for PDF/DOCX
  footerNote    String?                        // Custom footer text on exports
  brandColor    String?                        // Hex accent color e.g. #2563eb
  headerBg      String?                        // Report header background hex
  updatedAt     DateTime  @updatedAt
}

model InspectSchedule {
  id            String         @id @default(cuid())
  projectId     String
  project       InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime                               // When the inspection is due
  title         String                                 // e.g. "Q2 Structural Inspection"
  notes         String?                                // Inspector notes / prep instructions
  notifyEmail   String?                                // Send reminder to this email
  status        String         @default("pending")     // pending|completed|cancelled
  recurrence    String?                                // none|weekly|monthly|quarterly
  completedAt   DateTime?
  reminderSentAt DateTime?                             // When last reminder email was sent
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([userId])
}

model InspectProjectMember {
  id        String         @id @default(cuid())
  projectId String
  project   InspectProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email     String                       // invited inspector email
  userId    String?                      // populated if they have a Biddaro account
  role      String         @default("inspector")  // inspector|viewer
  addedBy   String                       // userId of project owner who added them
  name      String?                      // display name (filled from User if found)
  createdAt DateTime       @default(now())

  @@unique([projectId, email])
  @@index([projectId])
  @@index([userId])
}

model PushLog {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  body        String?
  fcmSent     Int      @default(0)
  vapidSent   Int      @default(0)
  fcmFailed   Int      @default(0)
  vapidFailed Int      @default(0)
  sentAt      DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sentAt])
}

model SocialPost {
  id           String    @id @default(cuid())
  topic        String                        // the theme this post was generated around
  platform     String    @default("instagram") // suggested target: instagram | facebook | linkedin
  caption      String    @default("")        // the post text/caption ("" for planned-but-not-generated slots)
  hashtags     String?                       // space-separated hashtags
  imagePrompt  String?                       // the prompt used to generate the image
  imageUrl     String?                       // S3 URL of the generated image (null if image gen unavailable)
  imageError   String?                       // why image generation failed, if it did (admin diagnostics)
  status       String    @default("draft")   // planned | draft | used | archived
  source       String    @default("auto")    // auto (cron) | manual (admin "generate now")
  scheduledFor DateTime?                      // calendar date this post is planned for
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([scheduledFor])
}

model ContractorSite {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug          String   @unique              // lowercase, [a-z0-9-]{3,40}
  enabled       Boolean  @default(true)
  headline      String?
  about         String?
  services      String?                       // JSON string[]
  accentColor   String?  @default("#EA580C")
  whatsapp      String?                       // Pro only
  showReviews   Boolean  @default(true)
  showPortfolio Boolean  @default(true)
  isPro         Boolean  @default(false)
  proExpiresAt  DateTime?
  views         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         WebsiteLead[]
}

model WebsiteLead {
  id        String         @id @default(cuid())
  siteId    String
  site      ContractorSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  message   String?
  createdAt DateTime       @default(now())

  @@index([siteId])
}
