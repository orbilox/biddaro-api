}

model BOQItem {
  id            String    @id @default(cuid())
  siteId        String
  site          SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category      String    @default("civil")  // civil|electrical|plumbing|finishing|structural|other
  description   String
  unit          String
  quantity      Float
  unitRate      Float
  totalAmount   Float
  completedQty  Float     @default(0)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SiteEquipment {
