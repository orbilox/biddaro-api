  createdAt     DateTime  @default(now())
}

model SiteExpense {
  id            String    @id @default(cuid())
  siteId        String
  site          SiteProject @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category      String    // labor | material | equipment | subcontractor | overhead | other
  description   String
  amount        Float
  currency      String    @default("INR")
  date          DateTime  @default(now())
  vendor        String?
  invoiceNumber String?
