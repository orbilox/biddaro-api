  labourCount   Int       @default(0)
  issues        String?
  photos        String?   // JSON array of photo URLs
  nextDayPlan   String?
  progressPct   Float     @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

