NODE_ENV=development
PORT=5000

# SQLite database file
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="biddaro_super_secret_jwt_key_change_in_production_32chars"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="biddaro_refresh_secret_key_change_in_production_32chars"
JWT_REFRESH_EXPIRY="30d"

# CORS
FRONTEND_URL="http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Platform fee (%)
PLATFORM_FEE_PERCENT=3.75

# Optional external services (leave blank to skip)
STRIPE_SECRET_KEY=""
OPENAI_API_KEY=""
SENDGRID_API_KEY=""
